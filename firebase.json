{
  "hosting": {
    "public": "frontend",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      }
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=0"
          }
        ]
      },
      {
        "source": "*.@(jpg|jpeg|gif|png|svg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=86400"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": ".",
    "ignore": [
      "frontend/**",
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "codebase": "default"
  },
  "emulators": {
    "functions": {
      "port": 5001
    },
    "hosting": {
      "port": 3000
    },
    "ui": {
      "enabled": true
    }
  }
}